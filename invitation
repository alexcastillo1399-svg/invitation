<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invitation</title>
    <style>
        body { 
            margin: 0; min-height: 100vh; display: flex; align-items: center; 
            justify-content: center; background: #14121f; font-family: sans-serif; 
        }
        .wrapper { width: 659px; height: 500px; perspective: 1000px; }
        .card { 
            width: 100%; height: 100%; position: relative; 
            transform-style: preserve-3d; transition: transform 0.6s; cursor: pointer; 
        }
        .card.flipped { transform: rotateY(180deg); }
        .face { 
            position: absolute; width: 100%; height: 100%; 
            backface-visibility: hidden; border-radius: 20px; 
            overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
        }
        /* Ensure these filenames match your actual files */
        .front { background-image: url('mexico-front.png'); background-size: cover; background-position: center; }
        .back { transform: rotateY(180deg); background-image: url('watermarked_img_12409857875665502615.png'); background-size: cover; background-position: center; }

        .form-container {
            max-width: 660px;
            margin: 30px auto 0;
            padding: 20px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.35);
            color: #f5f5f5;
        }
        .form-container h2 {
            margin: 0 0 16px;
            font-size: 1.6rem;
            text-align: center;
        }
        .form-container form {
            display: grid;
            gap: 16px;
        }
        .form-container label {
            display: grid;
            gap: 8px;
            font-size: 0.95rem;
        }
        .radio-row {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }
        .radio-row label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.95rem;
        }
        .form-container input,
        .form-container textarea {
            width: 100%;
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.18);
            background: rgba(255,255,255,0.08);
            color: #fff;
            font-size: 1rem;
            outline: none;
        }
        .form-container input::placeholder,
        .form-container textarea::placeholder {
            color: rgba(255,255,255,0.7);
        }
        .food-grid {
            display: grid;
            gap: 16px;
        }
        .checkbox-grid {
            display: grid;
            gap: 12px;
            padding-left: 4px;
        }
        .form-container label.checkbox-label {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.95rem;
        }
        .summary {
            margin: 0;
            color: #ffd9b8;
            font-size: 0.95rem;
            text-align: center;
        }
        .visually-hidden {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0,0,0,0);
            white-space: nowrap;
            border: 0;
        }
        .form-container button {
            width: fit-content;
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            background: #ff7a59;
            color: #14121f;
            font-weight: 700;
            cursor: pointer;
            justify-self: center;
        }
        .form-container button:hover {
            background: #ff8f70;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="card" id="card" onclick="this.classList.toggle('flipped')" aria-label="Invitation card" role="button">
            <div class="face front" aria-label="Front of invitation"><span class="visually-hidden">Front of invitation</span></div>
            <div class="face back" aria-label="Back of invitation"><span class="visually-hidden">Back of invitation</span></div>
        </div>
    </div>

    <div class="form-container">
        <h2>RSVP / Confirmación</h2>
        <form>
            <label for="name">Nombre / Name</label>
            <input id="name" type="text" name="name" placeholder="Juan / John" />

            <fieldset>
                <legend>¿Vas a asistir? / Are you going?</legend>
                <div class="radio-row">
                    <label for="attendance-yes"><input id="attendance-yes" type="radio" name="attendance" value="yes" /> Sí / Yes</label>
                    <label for="attendance-no"><input id="attendance-no" type="radio" name="attendance" value="no" /> No / No</label>
                </div>
            </fieldset>

            <label for="guests">¿Cuántos van a asistir? / How many are going?</label>
            <input id="guests" type="number" name="guests" min="1" value="1" placeholder="1" />

            <p class="summary" role="status" aria-live="polite">Total de personas que vienen / Total people coming: <span id="totalCount">1</span></p>
            <p class="summary">Se enviará a: alexcastillo1399@gmail.com</p>
            <p class="summary" id="bringingSummary" role="status" aria-live="polite">Está trayendo / Bringing: ---</p>

            <fieldset>
                <legend>¿Qué vas a traer? / What are you going to bring?</legend>
                <div class="checkbox-grid">
                    <label class="checkbox-label" for="bringSides">Acompañamientos / Sides <input id="bringSides" type="checkbox" name="bringSides" /></label>
                    <label class="checkbox-label" for="bringMain">Plato principal / Main <input id="bringMain" type="checkbox" name="bringMain" /></label>
                    <label class="checkbox-label" for="bringDrinks">Bebidas / Drinks <input id="bringDrinks" type="checkbox" name="bringDrinks" /></label>
                    <label class="checkbox-label" for="bringDesserts">Postres / Desserts <input id="bringDesserts" type="checkbox" name="bringDesserts" /></label>
                </div>
            </fieldset>

            <label for="other">Otro / Other</label>
            <textarea id="other" name="other" rows="3" placeholder="Escribe lo que vas a traer / Type what you will bring"></textarea>

            <button type="submit">Enviar / Submit</button>
        </form>
    </div>
    <script>
        const form = document.querySelector('.form-container form');
        const totalCount = document.getElementById('totalCount');
        const bringingSummary = document.getElementById('bringingSummary');
        const guestsInput = form.elements.guests;
        const attendanceRadios = Array.from(form.elements.attendance);
        const bringCheckboxes = [
            {el: form.elements.bringSides, label: 'Acompañamientos / Sides'},
            {el: form.elements.bringMain, label: 'Plato principal / Main'},
            {el: form.elements.bringDrinks, label: 'Bebidas / Drinks'},
            {el: form.elements.bringDesserts, label: 'Postres / Desserts'}
        ];
        const otherInput = form.elements.other;
        const nameInput = form.elements.name;

        function updateTotal() {
            const attendance = form.elements.attendance.value;
            const guests = Number(guestsInput.value) || 0;
            totalCount.textContent = attendance === 'yes' ? guests : 0;
        }

        function updateBringing() {
            const name = nameInput.value.trim();
            const chosen = bringCheckboxes
                .filter(item => item.el.checked)
                .map(item => item.label);
            if (otherInput.value.trim()) {
                chosen.push(`Otro / Other: ${otherInput.value.trim()}`);
            }
            const list = chosen.length ? chosen.join(', ') : '---';
            bringingSummary.textContent = `${name ? `${name} está trayendo / ${name} is bringing:` : 'Está trayendo / Bringing:'} ${list}`;
        }

        guestsInput.addEventListener('input', updateTotal);
        attendanceRadios.forEach(radio => radio.addEventListener('change', updateTotal));
        bringCheckboxes.forEach(item => item.el.addEventListener('change', updateBringing));
        otherInput.addEventListener('input', updateBringing);
        nameInput.addEventListener('input', updateBringing);
        updateTotal();
        updateBringing();

        form.addEventListener('submit', event => {
            event.preventDefault();
            const name = form.elements.name.value.trim();
            const attendance = form.elements.attendance.value || 'no';
            const guests = Number(guestsInput.value) || 0;
            const bringSides = form.elements.bringSides.checked;
            const bringMain = form.elements.bringMain.checked;
            const bringDrinks = form.elements.bringDrinks.checked;
            const bringDesserts = form.elements.bringDesserts.checked;
            const other = form.elements.other.value.trim();
            const sendTo = 'alexcastillo1399@gmail.com';

            const bringing = [];
            if (bringSides) bringing.push('Acompañamientos / Sides');
            if (bringMain) bringing.push('Plato principal / Main');
            if (bringDrinks) bringing.push('Bebidas / Drinks');
            if (bringDesserts) bringing.push('Postres / Desserts');
            if (other) bringing.push(`Otro / Other: ${other}`);
            const bringingText = bringing.length ? bringing.join(', ') : '---';

            const subject = 'Invitation';
            const bodyLines = [
                `Nombre / Name: ${name || '---'}`,
                `Asistencia / Attendance: ${attendance === 'yes' ? 'Sí / Yes' : 'No / No'}`,
                `Total de personas / Total people coming: ${attendance === 'yes' ? guests : 0}`,
                `Trayendo / Bringing: ${bringingText}`
            ];
            const body = encodeURIComponent(bodyLines.join('\n'));
            window.location.href = `mailto:alexcastillo1399@gmail.com?subject=${subject}&body=${body}`;
        });
    </script>
</body>
</html>
